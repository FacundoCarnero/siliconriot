// ============================================================
// Firestore Security Rules — Silicon Riot
// Copiá este bloque ENTERO en Firebase Console > Firestore > Rules.
// ============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Site Config: ADMIN (API Keys, Secrets) ─────────────
    // SOLO admin autenticado puede leer/escribir.
    // Acá viven: youtubeApiKey, youtubeChannelId, siteUrl,
    // spotifyClientId, spotifyClientSecret, spotifyArtistId
    match /site_config/general {
      allow read, write: if request.auth != null;
      allow delete: if false;
    }

    // ─── Site Config: PÚBLICO (datos visibles en el site) ──
    // READ: cualquiera. WRITE: solo admin autenticado.
    // Acá viven: heroTagline, heroDescription, ctaText,
    // spotifyUrl, instagramUrl, youtubeUrl, beaconsUrl,
    // footerText, announcement
    match /site_config/public {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if false;
    }

    // ─── VIP Passes ─────────────────────────────────────────
    // Lectura: pública. Creación: pública. Modificación: admin.
    match /vip_passes/{pass} {
      allow read: if true;
      allow create: if true;
      allow delete: if request.auth != null;
      allow update: if request.auth != null;
    }

    // ─── Albums ────────────────────────────────────────────
    // Lectura: pública. Escritura: solo admin.
    match /albums/{album} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ─── Default: denegar todo lo demás ─────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
